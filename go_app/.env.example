# ──────────────────────────────────────────────────────────────────────────────
# Environment variables for the portfolio Go app
# Copy this file to .env and fill in the values. Never commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# Turso (libsql) remote database URL — includes the auth token in the URL
TURSO_DATABASE_URL=

# JWT signing secret — generate with: openssl rand -hex 32
# MUST be set before starting the server.
JWT_SECRET=

# Invite code required for new user registration.
# Set to any value to lock signups; leave EMPTY to allow open registration.
INVITE_CODE=
